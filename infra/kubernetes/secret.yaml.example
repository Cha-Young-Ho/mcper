# 실제 secret 파일은 .gitignore로 절대 커밋 금지
# 생성 방법:
#   kubectl create secret generic mcper-secret \
#     --namespace mcper \
#     --from-env-file=.env \
#     --dry-run=client -o yaml > secret.yaml
#
# 또는 아래 템플릿을 복사해서 secret.yaml로 사용 (base64 인코딩 필수)
apiVersion: v1
kind: Secret
metadata:
  name: mcper-secret
  namespace: mcper
type: Opaque
stringData:
  DATABASE_URL: "postgresql://user:password@postgres-service:5432/mcpdb"
  CELERY_BROKER_URL: "redis://redis-service:6379/0"
  CELERY_RESULT_BACKEND: "redis://redis-service:6379/0"
  ADMIN_USER: "admin"
  ADMIN_PASSWORD: "changeme_strong_password"
  AUTH_SECRET_KEY: "your-random-secret-key-min-32-chars"
  # AUTH_GOOGLE_CLIENT_ID: ""
  # AUTH_GOOGLE_CLIENT_SECRET: ""
  # AUTH_GITHUB_CLIENT_ID: ""
  # AUTH_GITHUB_CLIENT_SECRET: ""
