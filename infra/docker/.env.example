# infra/docker/.env.example
# cp .env.example .env 후 값 변경 (사내 운영 시 반드시 비밀번호/키 변경)
# .env 파일은 .gitignore에 포함 — 절대 커밋 금지

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@db:5432/mcpdb
DB_USER=user
# 반드시 변경
DB_PASSWORD=changeme_strong_password
DB_NAME=mcpdb
DB_PORT=5433

# ── Redis / Celery ────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_PORT=6380

# ── Admin ─────────────────────────────────────────────────────
ADMIN_USER=admin
# 반드시 변경 (비워두면 startup 경고)
ADMIN_PASSWORD=changeme_strong_password
MCPER_WEB_PORT=8001

# ── 사내(Private Network) 바인드 설정 ─────────────────────────
# 프로덕션: 127.0.0.1 (로컬호스트만), 사내 리버스 프록시(Nginx 등) 앞단에 둘 것
# 개발: 0.0.0.0 (docker-compose.override.yml에서 자동 적용)
MCPER_HOST_BIND=127.0.0.1

# ── Embedding ─────────────────────────────────────────────────
EMBEDDING_DIM=384
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# OPENAI_API_KEY=
# BEDROCK_REGION=

# ── Feature Flags ─────────────────────────────────────────────
MCPER_ADMIN_ENABLED=true
MCPER_MCP_ENABLED=true
# 사내 사용 시 true 권장
MCPER_AUTH_ENABLED=false

# MCP OAuth (RFC 9728/8414) — HTTPS 필수.
# HTTP 환경(로컬/내부망 IP)에서는 false, HTTPS 도메인 연결 후 true 로 전환.
# 미설정 시 MCPER_AUTH_ENABLED 값을 따라감.
# MCPER_MCP_AUTH_ENABLED=false

# MCP OAuth 가 클라이언트에 반환하는 외부 주소 (스키마 제외).
# MCPER_MCP_AUTH_ENABLED=true 시 필수. 예: mcp.example.com
# MCPER_PUBLIC_HOST=mcp.example.com

# ── Auth (MCPER_AUTH_ENABLED=true 시 필수) ─────────────────────
# AUTH_SECRET_KEY=your-random-secret-key-min-32-chars
# AUTH_TOKEN_EXPIRE_MINUTES=1440
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=

# ── MCP 보안 ──────────────────────────────────────────────────
MCP_BYPASS_TRANSPORT_GATE=false

# Phase 3: OAuth/MCP 세션 스토어 (memory | redis)
# memory: 프로세스 메모리 (기본, 단일 인스턴스)
# redis: Redis 외부화 (로드밸런서 뒤 여러 인스턴스 운영 시 필요)
# redis 선택 시 REDIS_URL 또는 CELERY_BROKER_URL 필수. 미설정이면 memory 로 폴백.
MCPER_SESSION_STORE=memory

# ── CSRF 쿠키 ──────────────────────────────────────────────────
# 프로덕션 HTTPS 환경에서는 true (로컬 HTTP 개발 시 false)
CSRF_COOKIE_SECURE=true
# MCP_ALLOWED_HOSTS=your-internal-host.corp:8001

# ── Uvicorn ───────────────────────────────────────────────────
# 프로덕션은 리로드 없음 (로컬은 --reload --reload-dir /app)
UVICORN_EXTRA_OPTS=

# ── Logging ───────────────────────────────────────────────────
LOG_FORMAT=json
LOG_LEVEL=INFO
